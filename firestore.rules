rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth()  { return request.auth != null; }
    function isOwner(uid) { return request.auth.uid == uid; }
    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid))
          .data.role == 'admin';
    }

    // Jobs — public read, employer/admin write
    match /jobs/{jobId} {
      allow read: if true;
      allow create: if isAuth();
      allow update, delete: if isAuth() && (
        resource.data.employerId == request.auth.uid || isAdmin()
      );
    }

    // Users — authenticated read, own write
    match /users/{userId} {
      allow read:  if isAuth();
      allow write: if isOwner(userId) || isAdmin();
    }

    // Applications
    match /applications/{appId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
    }

    // Notifications — own only
    match /notifications/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }

    // Chats — participants only
    match /chats/{chatId} {
      allow read, write: if isAuth() &&
        request.auth.uid in resource.data.participants;
      match /messages/{msgId} {
        allow read, write: if isAuth();
      }
    }

    // Admin broadcasts — admin only
    match /admin_broadcasts/{doc} {
      allow read, write: if isAdmin();
    }
  }
}
